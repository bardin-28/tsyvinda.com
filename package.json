{
  "name": "tsyvinda.com",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:https": "NODE_OPTIONS='--max-old-space-size=4096' next dev --experimental-https --experimental-https-key ./certs/local.tsyvinda.com-key.pem --experimental-https-cert ./certs/local.tsyvinda.com.pem -H local.tsyvinda.com -p 443",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --config config/jest/jest.config.ts",
    "test:watch": "jest --config config/jest/jest.config.ts --watch",
    "test:ci": "jest --config config/jest/jest.config.ts --ci --coverage",
    "test:e2e": "playwright test -c config/playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test -c config/playwright/playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report",
    "storybook": "NODE_OPTIONS='--max-old-space-size=4096' storybook dev -p 6006 -c config/storybook",
    "build-storybook": "NODE_OPTIONS='--max-old-space-size=4096' storybook build -c config/storybook"
  },
  "dependencies": {
    "antd": "^6.4.3",
    "formik": "^2.4.9",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.23",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/nextjs": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "storybook": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
