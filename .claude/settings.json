{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(rtk git diff *)",
      "Bash(git add *)",
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Read(**/.env.example)",
      "Edit(**/.env.example)",
      "Write(**/.env.example)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.env*)",
      "Read(**/.dev.vars*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/config/database.yml)",
      "Read(**/config/credentials.json)",
      "Read(**/.npmrc)",
      "Write(**/.env*)",
      "Write(**/secrets/**)",
      "Write(**/.ssh/**)"
    ],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "aws-agents@claude-plugins-official": false,
    "claude-seo@agricidaniel-claude-seo": true
  },
  "sandbox": {
    "enabled": true
  },
  "additionalDirectories": [
    "../test-be"
  ]
}
