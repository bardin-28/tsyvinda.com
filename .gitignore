# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/playwright-report
/test-results
/blob-report
/e2e/.auth

# storybook
/storybook-static

# next.js
/.next/
/.next-e2e/
/out/

# production
/build

# seo audit output
/seo-audit-output

# misc
.DS_Store
*.pem
/certs
.idea
.swc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.*
.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
